{
  "name": "skilldelta",
  "private": true,
  "version": "0.1.0",
  "description": "SkillDelta AI Career Intelligence Platform",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "lint": "npm run lint --workspace frontend",
